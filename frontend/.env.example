# Frontend (Vite SPA) environment.
# Copy to `frontend/.env` (or `.env.local` / `.env.production`) - Vite loads files from this folder
# (vite.config.ts has `envDir: __dirname`). VITE_* values are baked into the static bundle at build
# time; rebuild + redeploy after changing them.
#
# Same-domain production (Nginx serves the SPA and proxies /api/*): leave VITE_API_BASE_URL empty
# so the SPA hits relative `/api/*` URLs and shares cookies / origin with the backend.

# Local dev: Vite proxies /api -> http://127.0.0.1:4000 (see vite.config.ts), so this can stay empty.
# Easiest: from the download root (parent of PayToday-Mobile-App-Design-main/), run `npm run dev` to start API + Vite together.
# Cross-origin override (rare): VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Vite dev proxy only (not exposed to the client bundle). If the API listens on another host/port:
# DEV_API_PROXY=http://127.0.0.1:4001

# Optional dev override - default is 5173.
# VITE_DEV_PORT=5173

# Optional: set to `false` to hide checkout “Demo addresses” presets (Windhoek examples for training).
# VITE_SHOW_CHECKOUT_DEMO_PRESETS=

# Optional: Google Maps JavaScript API key for live checkout / address maps.
# Leave unset, or set to `demo` / `placeholder`, to use the built-in static map preview (zones still load from the API / DB).
# VITE_GOOGLE_MAPS_API_KEY=
