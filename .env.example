# Copy to `.env` in the repo root. Do not commit real secrets.
#
# --- Bootstrap only (cannot live in dbo.integration_settings) ---
#   SQL_CONNECTION_STRING — required to reach SQL Server
#   JWT_SECRET — required to sign sessions
#   PORT, NODE_ENV, CORS_ORIGINS — process / HTTP
#
# --- Integration secrets & URLs (Keycloak, PayToday, Notify) ---
#   Store them in dbo.integration_settings (non-empty values override env).
#   Run: npm run db:migrate
#   Then either:
#     npm run db:seed-integration   (uses backend/scripts/integration-settings.seed.json — copy from .example.json)
#     or edit & execute: backend/scripts/seed-integration-settings.template.sql in SSMS
#   Keys list: backend/src/services/integrationRuntimeConfig.ts
#

PORT=4000
JWT_SECRET=change-me-in-production

# MS SQL — required for checkout, auth DB users, and integration_settings overrides
# SQL_CONNECTION_STRING=Server=127.0.0.1,1433;Database=paytoday;User Id=sa;Password=...;Encrypt=true;TrustServerCertificate=true;Connection Timeout=30

# Origins allowed to call the API (include every host/port you use in the browser)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Optional: when the SPA is opened without the Vite /api proxy (Simple Browser, file preview, etc.)
# Must match CORS_ORIGINS. Vite also loads this from repo root when envDir is configured in vite.config.ts.
# VITE_API_BASE_URL=http://127.0.0.1:4000

# Public URLs (email deep links, PayToday callbacks; non-empty .env overrides integration_settings)
PUBLIC_STORE_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000

# Today notify — transactional email (same keys can be stored in dbo.integration_settings instead)
NOTIFY_SERVICE_BASE_URL=https://notify-service.today-ww.net/api/v1
# When set, POST goes to {NOTIFY_SERVICE_BASE_URL}/{NOTIFY_SERVICE_PORTAL}/email
NOTIFY_SERVICE_PORTAL=
NOTIFY_SERVICE_API_KEY=
# Inbox path after portal (public-config exposes notifyInboxUrl for SPA deep links)
NOTIFY_SERVICE_INBOX_PATH=/notifications
NOTIFICATION_EMAIL_FROM=
# NOTIFY_EMAIL_TEMPLATE_IDS={"checkout_pending_payment":"","payment_confirmed":""}

# Optional: notification worker POSTs in_app payloads (see backend/src/services/notificationWorker.ts)
# NOTIFICATION_APP_WEBHOOK_URL=

# Shipping / tax defaults (non-secret; can stay here)
CHECKOUT_REQUIRE_SIGN_IN=false
SHIPPING_FLAT_CENTS=0
SHIPPING_FREE_SUBTOTAL_CENTS=0
VAT_RATE_BPS=0
COOKIE_SAME_SITE=strict

# Dev only
ALLOW_DEV_ROLE_HEADER=false
NODE_ENV=development

# Optional: SMTP for other features (non-integration-service)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
