# =============================================================================
# AvoToday production — copy to the SERVER as:
#   /var/www/avotoday-production/shared/.env
# Then: chmod 600 /var/www/avotoday-production/shared/.env
#
# Replace every CHANGEME / __...__ value. Do not commit a filled copy to git.
# See: deploy/avotoday-rollout.md, docs/DEPLOY.md, .env.example
# =============================================================================

NODE_ENV=production
PORT=4000

# Strong random secret (e.g. pwsh: [Convert]::ToBase64String((1..48|%{Get-Random -Max 256}) -as [byte[]]))
JWT_SECRET=CHANGEME_GENERATE_LONG_RANDOM_SECRET

# Behind Nginx TLS termination — required for secure cookies / correct client IP
TRUST_PROXY=true

# -----------------------------------------------------------------------------
# MS SQL (Linux app server must use SQL auth — not Trusted_Connection)
# Match Database= to the database you created (e.g. paytoday or paytoday_store).
# -----------------------------------------------------------------------------
SQL_CONNECTION_STRING=Server=YOUR_SQL_HOST,1433;Database=paytoday_store;User Id=YOUR_APP_LOGIN;Password=CHANGEME_SQL_PASSWORD;Encrypt=true;TrustServerCertificate=false;Connection Timeout=30

# Optional: if SQL host/port is awkward, you can use SQL_SERVER_TCP=host,port and a minimal string — see backend/src/config/env.ts

# -----------------------------------------------------------------------------
# Browser / public URLs (Option C: same origin, no trailing slash)
# -----------------------------------------------------------------------------
PUBLIC_STORE_URL=https://avotoday.today-ww.net
PUBLIC_API_URL=https://avotoday.today-ww.net
CORS_ORIGINS=https://avotoday.today-ww.net

# SameSite: strict is fine for same-site SPA+API. Use "none" only for embedded WebViews / cross-site cookies (requires Secure) — see docs/DEPLOY.md
COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# PayToday / Forms (production — set from PayToday / integration docs)
# -----------------------------------------------------------------------------
PAYTODAY_FORMS_BASE_URL=
PAYTODAY_FORMS_API_URL=
PAYTODAY_PAYMENT_INTENT_URL=
PAYTODAY_VENDOR_ID=
PAYTODAY_BUSINESS_ID=
PAYTODAY_WEBHOOK_SECRET=CHANGEME_WEBHOOK_HMAC_SECRET

# -----------------------------------------------------------------------------
# Keycloak (PayToday sign-in via API — see docs/KEYCLOAK_API.md)
# -----------------------------------------------------------------------------
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# When true, integration_settings in SQL is ignored — only env drives PayToday/Keycloak/notify
# INTEGRATION_USE_ENV_ONLY=false

# -----------------------------------------------------------------------------
# Notifications (Today notify service — optional)
# -----------------------------------------------------------------------------
NOTIFY_SERVICE_BASE_URL=https://notify-service.today-ww.net/api/v1
NOTIFY_SERVICE_PORTAL=
NOTIFY_SERVICE_API_KEY=
NOTIFY_SERVICE_INBOX_PATH=/notifications
NOTIFICATION_EMAIL_FROM=

# -----------------------------------------------------------------------------
# SMTP (optional fallback if notify is not used)
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# -----------------------------------------------------------------------------
# Store behaviour (safe defaults)
# -----------------------------------------------------------------------------
CHECKOUT_REQUIRE_SIGN_IN=false
SHIPPING_FLAT_CENTS=0
SHIPPING_FREE_SUBTOTAL_CENTS=0
VAT_RATE_BPS=0
# STORE_RETURN_WINDOW_DAYS=90

# Production must stay false
ALLOW_DEV_ROLE_HEADER=false

# SPA is served by PM2 via SPA_STATIC_ROOT in ecosystem.config.js — no need to duplicate here unless you run node by hand.
