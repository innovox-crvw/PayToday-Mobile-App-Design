# =============================================================================
# AvoToday frontend production — values are baked into the static bundle at
# `npm run build`. Place this file at:
#   frontend/.env.production       (committed-template free; never commit a filled copy)
#
# Re-run `deploy/avotoday-frontend-production.ps1` after changing any value.
# Vite resolves it from frontend/ because vite.config.ts sets `envDir: __dirname`.
# =============================================================================

# Same-domain prod (Nginx serves the SPA AND proxies /api/*): leave empty so the SPA hits
# relative `/api/*` URLs and shares cookies with the backend on the same origin.
VITE_API_BASE_URL=

# Cross-origin prod (e.g. api.avotoday.today-ww.net) — uncomment and set instead of the line above:
# VITE_API_BASE_URL=https://api.avotoday.today-ww.net
