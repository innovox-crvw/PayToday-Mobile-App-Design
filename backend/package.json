{
  "name": "paytoday-store-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AvoToday / PayToday Store Express API + MS SQL backend.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "db:up": "docker compose -f ../docker-compose.yml up -d",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:bootstrap": "tsx scripts/bootstrap-demo-database.ts",
    "db:demo-setup": "npm run db:prepare && npm run db:bootstrap && npm run db:migrate",
    "db:prepare": "tsx src/db/ensureDatabase.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:fix-columns": "tsx scripts/run-missing-columns.ts",
    "db:drop": "tsx src/db/dropDatabase.ts",
    "db:setup": "npm run db:prepare && npm run db:migrate",
    "db:seed-integration": "tsx scripts/seed-integration-settings.ts",
    "db:seed-variant-dimensions": "tsx scripts/seed-variant-package-dimensions.ts",
    "db:tcp-port": "powershell -ExecutionPolicy Bypass -File scripts/print-sqlexpress-tcp.ps1",
    "db:test-ts": "tsx src/db/testTsConnection.ts",
    "docs:docx": "node scripts/build-docs-docx.mjs"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/yauzl": "^2.10.3",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "html-to-docx": "^1.8.0",
    "marked": "^18.0.2",
    "supertest": "^7.2.2",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "msnodesqlv8": "^5.1.8"
  }
}
