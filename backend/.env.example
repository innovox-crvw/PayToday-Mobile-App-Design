# Backend (Express + MS SQL) environment.
# Copy to `backend/.env` for local dev, or place on the VM as `/var/www/avotoday-backend/shared/.env`
# (chmod 600). Never commit a filled copy.
#
# --- Bootstrap only ---
#   SQL_CONNECTION_STRING - required to reach SQL Server
#   JWT_SECRET            - required to sign sessions
#   PORT, NODE_ENV        - process / HTTP
#   BIND_HOST             - network interface to bind to (default: 127.0.0.1 in production, 0.0.0.0 in dev)
#   CORS_ORIGINS          - browser origins allowed with credentials
#
# --- Integration (Keycloak, PayToday, Notify) ---
#   Default: non-empty values in dbo.integration_settings override env (see integrationRuntimeConfig.ts).
#   Set INTEGRATION_USE_ENV_ONLY=true to never read that table - use only variables below + other PAYTODAY_*/KEYCLOAK_* in .env.
#

NODE_ENV=development
PORT=4000

# Loopback in production so the API is reachable only via Nginx; 0.0.0.0 in dev for phones / LAN.
# BIND_HOST=127.0.0.1

JWT_SECRET=change-me-in-production

# Behind Nginx TLS termination - required in production for secure cookies / correct client IP.
# TRUST_PROXY=true

# Set true when dbo.integration_settings is unused or removed - PayToday / Keycloak / notify use .env only.
# INTEGRATION_USE_ENV_ONLY=true

# MS SQL - required for checkout, auth DB users, and integration_settings overrides.
# Docker (`npm run db:up`): SA password matches docker-compose.yml.
# SQL_CONNECTION_STRING=Server=127.0.0.1,1433;Database=paytoday;User Id=sa;Password=PayTodayDemo1!;Encrypt=true;TrustServerCertificate=true;Connection Timeout=30
#
# Demo reset (schema + seed): npm run db:bootstrap   (then npm run db:migrate if not using db:demo-setup)

# Origins allowed to call the API with credentials (include every host/port the SPA is served from).
# Same-domain prod via Nginx: just `https://avotoday.today-ww.net`. Dev: Vite ports.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Public URLs (email deep links, PayToday callbacks; non-empty .env overrides integration_settings).
PUBLIC_STORE_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000

# Optional: folder for admin product image uploads (default: ./data/uploads/products under the process cwd).
# PRODUCT_IMAGE_UPLOAD_DIR=
# PRODUCT_IMAGE_UPLOAD_MAX_BYTES=4194304

# PayToday Notifications (Postman: docs/PayToday-Notifications-Service.postman_collection.json)
# NOTIFY_SERVICE_BASE_URL=http://localhost:3001/api/v1
NOTIFY_SERVICE_BASE_URL=https://notify-service.today-ww.net/api/v1
# POST URL: flat `{base}/email` when true (matches Postman "Send custom email"). Else `{base}/{NOTIFY_SERVICE_PORTAL}/email` if portal set.
# NOTIFY_SERVICE_USE_FLAT_EMAIL_PATH=true
NOTIFY_SERVICE_PORTAL=
NOTIFY_SERVICE_API_KEY=
# Inbox path after portal (public-config exposes notifyInboxUrl for SPA deep links).
NOTIFY_SERVICE_INBOX_PATH=/notifications
NOTIFICATION_EMAIL_FROM=
# NOTIFY_EMAIL_TEMPLATE_IDS={"checkout_pending_payment":"","payment_confirmed":""}

# Optional: notification worker POSTs in_app payloads (see backend/src/services/notificationWorker.ts).
# NOTIFICATION_APP_WEBHOOK_URL=

# Shipping / tax defaults (non-secret; can stay here).
CHECKOUT_REQUIRE_SIGN_IN=false
# Max days after order creation that a customer may request a post-delivery return (shipped/delivered orders).
# STORE_RETURN_WINDOW_DAYS=90
SHIPPING_FLAT_CENTS=0
SHIPPING_FREE_SUBTOTAL_CENTS=0
VAT_RATE_BPS=0
COOKIE_SAME_SITE=strict

# Dev only
ALLOW_DEV_ROLE_HEADER=false

# Outbound email (order / payment notifications): either Today notify (above) or SMTP below.
# The notification worker tries notify first when NOTIFY_SERVICE_API_KEY is set, then SMTP when SMTP_HOST is set.
# NOTIFICATION_EMAIL_FROM is required for SMTP sends.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Failed sign-in lockout (local bcrypt and PayToday/Keycloak throttle; see backend/src/routes/api/auth.ts)
# AUTH_LOCKOUT_MAX_ATTEMPTS=5
# AUTH_LOCKOUT_MINUTES=15

# --- Keycloak (PayToday sign-in) - minimal config; secrets never ship in the frontend bundle.
# Docs: docs/KEYCLOAK_API.md, docs/KEYCLOAK_AUTH_MODEL.md
# The SPA has its own sign-in/register pages and never redirects to Keycloak. When all three required
# fields below are set, `POST /api/auth/login` with `authSource: "paytoday"` calls the Keycloak token
# endpoint server-side and issues app cookies. Staff/admin roles are managed in-app via `users.role`.
#
# Keycloak Admin -> realm -> Clients -> your client: "Direct access grants" ON. If the client is confidential,
# copy Credentials -> Client secret into KEYCLOAK_CLIENT_SECRET. Public clients can leave it blank.
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
# PAYTODAY_FORGOT_PASSWORD_URL=
