{
  "name": "paytoday-store",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,blue \"npm run dev:api\" \"wait-on -t 120000 -i 400 http://127.0.0.1:4000/api/health && vite\"",
    "dev:web": "vite",
    "dev:api": "tsx watch backend/src/index.ts",
    "build": "tsc -b && vite build && npm run build:api",
    "build:api": "tsc -p backend/tsconfig.json",
    "start:api": "node backend/dist/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:bootstrap": "tsx backend/scripts/bootstrap-demo-database.ts",
    "db:demo-setup": "npm run db:prepare && npm run db:bootstrap && npm run db:migrate",
    "db:prepare": "tsx backend/src/db/ensureDatabase.ts",
    "db:migrate": "tsx backend/src/db/migrate.ts",
    "db:fix-columns": "tsx backend/scripts/run-missing-columns.ts",
    "db:drop": "tsx backend/src/db/dropDatabase.ts",
    "db:setup": "npm run db:prepare && npm run db:migrate",
    "db:seed-integration": "tsx backend/scripts/seed-integration-settings.ts",
    "db:seed-variant-dimensions": "tsx backend/scripts/seed-variant-package-dimensions.ts",
    "db:tcp-port": "powershell -ExecutionPolicy Bypass -File backend/scripts/print-sqlexpress-tcp.ps1",
    "db:test-ts": "tsx backend/src/db/testTsConnection.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "docs:docx": "node scripts/build-docs-docx.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.12",
    "@mui/material": "^6.4.12",
    "bcrypt": "^6.0.0",
    "msnodesqlv8": "^5.1.8",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.1.0",
    "globals": "^17.4.0",
    "helmet": "^8.1.0",
    "html-to-docx": "^1.8.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^18.0.2",
    "mssql": "^11.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
